# Local example:
# DATABASE_URL=postgres://postgres:password@localhost:5432/agentlink
# PGSSLMODE=disable
#
# Fly.io example:
# DATABASE_URL=postgres://<user>:<pass>@<host>:5432/<db>
# PGSSLMODE=require
DATABASE_URL=postgres://username:password@host:5432/dbname
PGSSLMODE=require
PORT=3000
HTTP_TIMEOUT_MS=10000
